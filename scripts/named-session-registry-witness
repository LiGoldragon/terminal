#!/usr/bin/env bash
set -euo pipefail

: "${PERSONA_TERMINAL_PACKAGE:?PERSONA_TERMINAL_PACKAGE must point at the built package}"
: "${PERSONA_TERMINAL_BASH:?PERSONA_TERMINAL_BASH must point at bash}"

root="${PERSONA_TERMINAL_TEST_ROOT:-$(mktemp -d -t persona-terminal-named-session.XXXXXX)}"
mkdir -p "$root"

store="$root/terminal.redb"
control_socket="$root/operator.control.sock"
data_socket="$root/operator.data.sock"
stdout="$root/daemon.stdout"
stderr="$root/daemon.stderr"
sessions="$root/sessions.tsv"
transcript="$root/transcript.raw"

cleanup() {
  if [ -n "${daemon_pid:-}" ]; then
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
  fi

  if [ "${PERSONA_TERMINAL_KEEP_ARTIFACTS:-1}" = "1" ]; then
    printf 'persona-terminal artifacts=%s\n' "$root"
  else
    rm -rf "$root"
  fi
}
trap cleanup EXIT

export PERSONA_SOCKET_MODE=600
"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-daemon" \
  --store "$store" \
  --name operator \
  --control-socket "$control_socket" \
  --data-socket "$data_socket" \
  -- "$PERSONA_TERMINAL_BASH" -lc 'printf "terminal-ready\n"; cat' \
  >"$stdout" \
  2>"$stderr" &
daemon_pid="$!"

for _ in $(seq 1 100); do
  if [ -S "$control_socket" ] \
    && [ -S "$data_socket" ] \
    && grep -Fq "persona-terminal-daemon control-socket=$control_socket" "$stdout"; then
    break
  fi
  sleep 0.05
done

test -S "$control_socket"
test -S "$data_socket"
grep -Fq "persona-terminal-daemon control-socket=$control_socket" "$stdout"
grep -Fq "data-socket=$data_socket" "$stdout"
test "$(stat -c '%a' "$control_socket")" = "600"
test "$(stat -c '%a' "$data_socket")" = "600"

"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-sessions" --store "$store" >"$sessions"
expected_row="$(printf 'operator\t%s\t%s\tready' "$control_socket" "$data_socket")"
grep -Fq "$expected_row" "$sessions"

resolved="$("$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-resolve" --store "$store" operator)"
test "$resolved" = "$control_socket"

"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-send" "$resolved" named-input-from-sema

for _ in $(seq 1 100); do
  "$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-capture" "$resolved" >"$transcript" || true
  if grep -aFq "named-input-from-sema" "$transcript"; then
    break
  fi
  sleep 0.05
done

grep -aFq "named-input-from-sema" "$transcript"
printf 'persona-terminal named-session registry witness=passed\n'

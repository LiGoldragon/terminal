#!/usr/bin/env bash
set -euo pipefail

: "${TERMINAL_PACKAGE:?TERMINAL_PACKAGE must point at the built package}"
: "${TERMINAL_BASH:?TERMINAL_BASH must point at bash}"

root="${TERMINAL_TEST_ROOT:-$(mktemp -d -t terminal-dirty.XXXXXX)}"
mkdir -p "$root"

store="$root/terminal.redb"
control_socket="$root/operator.control.sock"
data_socket="$root/operator.data.sock"
stdout="$root/daemon.stdout"
stderr="$root/daemon.stderr"
pattern_event="$root/pattern.event"
gate_event="$root/gate.event"
injection_event="$root/injection.event"
release_event="$root/release.event"
capture="$root/capture.txt"

cleanup() {
  if [ -n "${daemon_pid:-}" ]; then
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
  fi

  if [ "${TERMINAL_KEEP_ARTIFACTS:-1}" = "1" ]; then
    printf 'terminal dirty-prompt artifacts=%s\n' "$root"
  else
    rm -rf "$root"
  fi
}
trap cleanup EXIT

"$TERMINAL_PACKAGE/bin/terminal-daemon" \
  --store "$store" \
  --name operator \
  --control-socket "$control_socket" \
  --data-socket "$data_socket" \
  -- "$TERMINAL_BASH" -lc 'printf "ready> "; while IFS= read -r line; do printf "signal-echo:%s\nready> " "$line"; done' \
  >"$stdout" \
  2>"$stderr" &
daemon_pid="$!"

for _ in $(seq 1 100); do
  if [ -S "$control_socket" ] \
    && [ -S "$data_socket" ] \
    && grep -Fq "terminal-daemon control-socket=$control_socket" "$stdout"; then
    break
  fi
  sleep 0.05
done

test -S "$control_socket"
test -S "$data_socket"
grep -Fq "terminal-daemon control-socket=$control_socket" "$stdout"
grep -Fq "data-socket=$data_socket" "$stdout"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$control_socket" \
  --terminal operator \
  register-literal-prompt 'ready> ' \
  >"$pattern_event"
grep -Fq $'PromptPatternRegistered\toperator\t' "$pattern_event"
pattern_id="$(awk -F '\t' '/^PromptPatternRegistered/ { print $3 }' "$pattern_event")"
test -n "$pattern_id"

"$TERMINAL_PACKAGE/bin/terminal-type" \
  "$control_socket" \
  'human-draft'

for _ in $(seq 1 100); do
  "$TERMINAL_PACKAGE/bin/terminal-capture" "$control_socket" >"$capture" || true
  if grep -Fq 'human-draft' "$capture"; then
    break
  fi
  sleep 0.05
done
grep -Fq 'human-draft' "$capture"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$control_socket" \
  --terminal operator \
  acquire-gate "$pattern_id" \
  >"$gate_event"
grep -Fq $'GateAcquired\toperator\t' "$gate_event"
grep -Fq $'\tDirty:' "$gate_event"
lease_id="$(awk -F '\t' '/^GateAcquired/ { print $3 }' "$gate_event")"
test -n "$lease_id"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$control_socket" \
  --terminal operator \
  inject-prompt "$lease_id" should-not-write \
  >"$injection_event"
grep -Fq $'InjectionRejected\toperator\tDirtyPrompt' "$injection_event"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$control_socket" \
  --terminal operator \
  release-gate "$lease_id" \
  >"$release_event"
grep -Fq $'GateReleased\toperator\t' "$release_event"

"$TERMINAL_PACKAGE/bin/terminal-capture" "$control_socket" >"$capture"
if grep -Fq "signal-echo:should-not-write" "$capture"; then
  printf 'dirty prompt injection reached PTY\n' >&2
  exit 1
fi

printf 'terminal dirty-prompt witness=passed\n'

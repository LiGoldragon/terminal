#!/usr/bin/env bash
set -euo pipefail

: "${PERSONA_TERMINAL_PACKAGE:?PERSONA_TERMINAL_PACKAGE must point at the built package}"
: "${PERSONA_TERMINAL_BASH:?PERSONA_TERMINAL_BASH must point at bash}"

root="${PERSONA_TERMINAL_TEST_ROOT:-$(mktemp -d -t persona-terminal-signal.XXXXXX)}"
mkdir -p "$root"

store="$root/terminal.redb"
socket="$root/operator.sock"
stdout="$root/daemon.stdout"
stderr="$root/daemon.stderr"
connect_event="$root/connect.event"
input_event="$root/input.event"
capture_event="$root/capture.event"

cleanup() {
  if [ -n "${daemon_pid:-}" ]; then
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
  fi

  if [ "${PERSONA_TERMINAL_KEEP_ARTIFACTS:-1}" = "1" ]; then
    printf 'persona-terminal signal artifacts=%s\n' "$root"
  else
    rm -rf "$root"
  fi
}
trap cleanup EXIT

"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-daemon" \
  --store "$store" \
  --name operator \
  --socket "$socket" \
  -- "$PERSONA_TERMINAL_BASH" -lc 'printf "terminal-ready\n"; while IFS= read -r line; do printf "signal-echo:%s\n" "$line"; done' \
  >"$stdout" \
  2>"$stderr" &
daemon_pid="$!"

for _ in $(seq 1 100); do
  if [ -S "$socket" ] && grep -Fq "persona-terminal-daemon socket=$socket" "$stdout"; then
    break
  fi
  sleep 0.05
done

test -S "$socket"
grep -Fq "persona-terminal-daemon socket=$socket" "$stdout"

resolved="$("$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-resolve" --store "$store" operator)"
test "$resolved" = "$socket"

"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-signal" \
  --socket "$resolved" \
  --terminal operator \
  connect \
  >"$connect_event"
grep -Fq $'TerminalReady\toperator\t1' "$connect_event"

"$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-signal" \
  --socket "$resolved" \
  --terminal operator \
  prompt signal-input-from-signal \
  >"$input_event"
grep -Fq $'TerminalInputAccepted\toperator\t1' "$input_event"

needle="$(printf 'signal-echo:signal-input-from-signal' | od -An -tx1 | tr -d ' \n')"
for _ in $(seq 1 100); do
  "$PERSONA_TERMINAL_PACKAGE/bin/persona-terminal-signal" \
    --socket "$resolved" \
    --terminal operator \
    capture \
    >"$capture_event" || true
  if grep -Fq "$needle" "$capture_event"; then
    break
  fi
  sleep 0.05
done

grep -Fq $'TerminalCaptured\toperator\t1' "$capture_event"
grep -Fq "$needle" "$capture_event"
printf 'persona-terminal signal witness=passed\n'

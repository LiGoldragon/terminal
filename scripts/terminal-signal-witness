#!/usr/bin/env bash
set -euo pipefail

: "${TERMINAL_PACKAGE:?TERMINAL_PACKAGE must point at the built package}"
: "${TERMINAL_BASH:?TERMINAL_BASH must point at bash}"

root="${TERMINAL_TEST_ROOT:-$(mktemp -d -t terminal-signal.XXXXXX)}"
mkdir -p "$root"

store="$root/terminal.redb"
control_socket="$root/operator.control.sock"
data_socket="$root/operator.data.sock"
stdout="$root/daemon.stdout"
stderr="$root/daemon.stderr"
connect_event="$root/connect.event"
input_event="$root/input.event"
capture_event="$root/capture.event"

cleanup() {
  if [ -n "${daemon_pid:-}" ]; then
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
  fi

  if [ "${TERMINAL_KEEP_ARTIFACTS:-1}" = "1" ]; then
    printf 'terminal signal artifacts=%s\n' "$root"
  else
    rm -rf "$root"
  fi
}
trap cleanup EXIT

"$TERMINAL_PACKAGE/bin/terminal-daemon" \
  --store "$store" \
  --name operator \
  --control-socket "$control_socket" \
  --data-socket "$data_socket" \
  -- "$TERMINAL_BASH" -lc 'printf "terminal-ready\n"; while IFS= read -r line; do printf "signal-echo:%s\n" "$line"; done' \
  >"$stdout" \
  2>"$stderr" &
daemon_pid="$!"

for _ in $(seq 1 100); do
  if [ -S "$control_socket" ] \
    && [ -S "$data_socket" ] \
    && grep -Fq "terminal-daemon control-socket=$control_socket" "$stdout"; then
    break
  fi
  sleep 0.05
done

test -S "$control_socket"
test -S "$data_socket"
grep -Fq "terminal-daemon control-socket=$control_socket" "$stdout"
grep -Fq "data-socket=$data_socket" "$stdout"

resolved="$("$TERMINAL_PACKAGE/bin/terminal-resolve" --store "$store" operator)"
test "$resolved" = "$control_socket"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$resolved" \
  --terminal operator \
  connect \
  >"$connect_event"
grep -Fq $'TerminalReady\toperator\t1' "$connect_event"

"$TERMINAL_PACKAGE/bin/terminal-signal" \
  --control-socket "$resolved" \
  --terminal operator \
  prompt signal-input-from-signal \
  >"$input_event"
grep -Fq $'TerminalInputAccepted\toperator\t1' "$input_event"

needle="$(printf 'signal-echo:signal-input-from-signal' | od -An -tx1 | tr -d ' \n')"
for _ in $(seq 1 100); do
  "$TERMINAL_PACKAGE/bin/terminal-signal" \
    --control-socket "$resolved" \
    --terminal operator \
    capture \
    >"$capture_event" || true
  if grep -Fq "$needle" "$capture_event"; then
    break
  fi
  sleep 0.05
done

grep -Fq $'TerminalCaptured\toperator\t1' "$capture_event"
grep -Fq "$needle" "$capture_event"
printf 'terminal signal witness=passed\n'
